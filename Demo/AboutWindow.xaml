<ui:FluentWindow x:Class="ApertureNeo.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="关于 Aperture Neo"
        Width="460" Height="360"
        MinWidth="380" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Foreground="{StaticResource TextPrimary}"
        Background="{StaticResource SurfaceCanvas}"
        WindowBackdropType="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceCanvas}"
                BorderBrush="{StaticResource BorderLineTint}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="关于" VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextTertiary}" FontSize="12" FontWeight="600"/>
                <Button HorizontalAlignment="Right" Width="32" Height="32" Margin="0,0,4,0"
                        Style="{StaticResource LinearCloseButton}" Click="BtnClose_Click">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="32,28,32,0">
            <!-- Brand mark -->
            <Border Width="56" Height="56" CornerRadius="12"
                    Background="{StaticResource BrandPrimary}"
                    HorizontalAlignment="Left" Margin="0,0,0,16">
                <ui:SymbolIcon Symbol="Image24" FontSize="28" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Aperture Neo" FontSize="24" FontWeight="500"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
            <TextBlock Text="Linear-style UI demo" FontSize="13"
                       Foreground="{StaticResource TextSecondary}" FontWeight="400"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Visual demo only — no installer, no release."
                       FontSize="12" Foreground="{StaticResource TextTertiary}" FontWeight="400"
                       Margin="0,0,0,20"/>

            <!-- Info card -->
            <Border Background="{StaticResource SurfacePanel}"
                    BorderBrush="{StaticResource BorderStandard}" BorderThickness="1"
                    CornerRadius="{StaticResource RadiusCard}"
                    Padding="14,12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="DEMO BUILD" FontSize="10" FontWeight="600"
                               Foreground="{StaticResource BrandAccent}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="feat/linear-demo branch" FontSize="13" FontWeight="500"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,2"/>
                    <TextBlock Text="Linear.app design system (spec) — palette, type, controls" FontSize="12"
                               Foreground="{StaticResource TextTertiary}" FontWeight="400"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource SurfacePanel}"
                BorderBrush="{StaticResource BorderLineTint}" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="© 2026 DJx · Inter OFL · JetBrains Mono OFL"
                           FontSize="11" Foreground="{StaticResource TextQuat}" FontWeight="500"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" x:Name="BtnOk" Click="BtnOk_Click"
                        MinWidth="80" Cursor="Hand" IsDefault="True"
                        Style="{StaticResource LinearPrimaryButton}">
                    <TextBlock Text="确定" FontSize="13" FontWeight="500"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
