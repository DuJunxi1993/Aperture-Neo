<Application x:Class="ApertureNeo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="/Demo/DesignTokens.xaml"/>
                <ResourceDictionary Source="/Demo/Styles/Buttons.xaml"/>
                <ResourceDictionary Source="/Demo/Styles/Splitter.xaml"/>
                <ResourceDictionary Source="/Demo/Styles/Text.xaml"/>
                <ResourceDictionary Source="/Demo/Styles/TreeView.xaml"/>
                <ResourceDictionary Source="/Demo/Styles/Thumbnail.xaml"/>
                <ResourceDictionary Source="/Demo/Styles/ContextMenu.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global default font -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontWeight" Value="400"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
            </Style>
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            </Style>
            <Style TargetType="Popup">
                <Setter Property="AllowsTransparency" Value="True"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
