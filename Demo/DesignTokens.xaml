<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Font families (Inter Variable + JetBrains Mono) — site-of-origin pack URI -->
    <FontFamily x:Key="FontPrimary">pack://siteoforigin:,,,/Demo/Fonts/InterVariable.ttf#Inter Variable Text</FontFamily>
    <FontFamily x:Key="FontMono">pack://siteoforigin:,,,/Demo/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono</FontFamily>
    <FontFamily x:Key="FontPrimaryFallback">Inter, Segoe UI Variable Display, Segoe UI, Arial</FontFamily>

    <!-- Border Radius scale -->
    <CornerRadius x:Key="RadiusMicro">2</CornerRadius>
    <CornerRadius x:Key="RadiusStd">4</CornerRadius>
    <CornerRadius x:Key="RadiusComfy">6</CornerRadius>
    <CornerRadius x:Key="RadiusCard">8</CornerRadius>
    <CornerRadius x:Key="RadiusPanel">12</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">22</CornerRadius>
    <!-- Pills are small rounded rectangles, not full ellipses. Linear's
         design uses consistent moderate radii (8px) for status/info pills
         rather than the WPF default "9999 = full ellipse" convention,
         which produces visually heavy oval shapes on wide content. -->
    <CornerRadius x:Key="RadiusPill">8</CornerRadius>

    <!-- Spacing -->
    <Thickness x:Key="PadXs">2,2,2,2</Thickness>
    <Thickness x:Key="PadSm">4,2,4,2</Thickness>
    <Thickness x:Key="PadMd">6,4,6,4</Thickness>
    <Thickness x:Key="PadLg">10,6,10,6</Thickness>
    <Thickness x:Key="PadXl">12,8,12,8</Thickness>
    <Thickness x:Key="PadButton">10,5,10,5</Thickness>
    <Thickness x:Key="PadButtonSm">6,3,6,3</Thickness>

    <!-- Surfaces (Linear layered luminance model) -->
    <SolidColorBrush x:Key="SurfaceCanvas"   Color="#FF08090a"/>
    <SolidColorBrush x:Key="SurfacePanel"    Color="#FF0b0c0d"/>
    <SolidColorBrush x:Key="SurfaceElevated" Color="#FF14151a"/>
    <SolidColorBrush x:Key="SurfaceHover"    Color="#FF1f2024"/>
    <SolidColorBrush x:Key="SurfaceOverlay"  Color="#D9000000"/>

    <!-- Selection — multi-signal activation (Linear-style, 10% indigo tint) -->
    <SolidColorBrush x:Key="SelectionBg"      Color="#1A5e6ad2"/>
    <SolidColorBrush x:Key="SelectionBgHover" Color="#245e6ad2"/>
    <SolidColorBrush x:Key="SelectionFg"      Color="#FFa5b0ff"/>
    <SolidColorBrush x:Key="SelectionBar"     Color="#FF8a93ff"/>
    <DropShadowEffect  x:Key="ShadowSelectionGlow" BlurRadius="14" ShadowDepth="0" Opacity="0.45" Color="#FF5e6ad2"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"   Color="#FFf7f8f8"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FFd0d6e0"/>
    <SolidColorBrush x:Key="TextTertiary"  Color="#FF8a8f98"/>
    <SolidColorBrush x:Key="TextQuat"      Color="#FF62666d"/>

    <!-- Brand (indigo / violet) -->
    <SolidColorBrush x:Key="BrandPrimary"  Color="#FF5e6ad2"/>
    <SolidColorBrush x:Key="BrandAccent"   Color="#FF7170ff"/>
    <SolidColorBrush x:Key="BrandHover"    Color="#FF828fff"/>
    <SolidColorBrush x:Key="BrandLavender" Color="#FF7a7fad"/>

    <!-- Borders (semi-transparent white) -->
    <SolidColorBrush x:Key="BorderSubtle"   Color="#0DFFFFFF"/>
    <SolidColorBrush x:Key="BorderStandard" Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="BorderSolid"    Color="#FF23252a"/>
    <SolidColorBrush x:Key="BorderSolidAlt" Color="#FF34343a"/>
    <SolidColorBrush x:Key="BorderLineTint" Color="#FF141516"/>

    <!-- Button backgrounds (nearly transparent white) -->
    <SolidColorBrush x:Key="BtnBgGhost"  Color="#08FFFFFF"/>
    <SolidColorBrush x:Key="BtnBgSubtle" Color="#0AFFFFFF"/>
    <SolidColorBrush x:Key="BtnBgHover"  Color="#0DFFFFFF"/>

    <!-- Status -->
    <SolidColorBrush x:Key="StatusGreen" Color="#FF10b981"/>
    <SolidColorBrush x:Key="StatusRed"   Color="#FFef4444"/>
    <SolidColorBrush x:Key="StatusAmber" Color="#FFfbbd41"/>

    <!-- Close button hover (subtle red) -->
    <SolidColorBrush x:Key="CloseBgHover"  Color="#26E81123"/>
    <SolidColorBrush x:Key="CloseBgPress"  Color="#40E81123"/>

    <!-- Shadows (Multi-layer hard shadows on dark surfaces) -->
    <DropShadowEffect x:Key="ShadowSubtle" BlurRadius="12" ShadowDepth="0" Opacity="0.2" Color="Black"/>
    <DropShadowEffect x:Key="ShadowElev"   BlurRadius="8"  ShadowDepth="2" Opacity="0.4" Color="Black"/>
    <DropShadowEffect x:Key="ShadowDialog" BlurRadius="24" ShadowDepth="8" Opacity="0.5" Color="Black"/>
    <DropShadowEffect x:Key="ShadowFocus"  BlurRadius="12" ShadowDepth="0" Opacity="0.1" Color="Black"/>
    <DropShadowEffect x:Key="ShadowGlow"   BlurRadius="16" ShadowDepth="0" Opacity="0.6" Color="#FF7170ff"/>

    <!-- Motion (Linear-style durations, wpf-friendly) -->
    <Duration x:Key="MotionMicro">0:0:0.15</Duration>          <!-- hover, icon swap -->
    <Duration x:Key="MotionStandard">0:0:0.20</Duration>       <!-- bg fade, button -->
    <Duration x:Key="MotionEmphasized">0:0:0.24</Duration>     <!-- panel/zoom -->
    <Duration x:Key="MotionPress">0:0:0.10</Duration>          <!-- press feedback -->

    <!-- Thumbnail card tokens (semantic, used by inline ItemTemplate) -->
    <SolidColorBrush x:Key="CardBg"          Color="#08FFFFFF"/>
    <SolidColorBrush x:Key="CardBgHover"     Color="#0DFFFFFF"/>
    <SolidColorBrush x:Key="CardBgSelected"  Color="#FF191a1b"/>
    <SolidColorBrush x:Key="CardBorder"      Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="CardBorderHover" Color="#28FFFFFF"/>
    <SolidColorBrush x:Key="CardBorderSelected" Color="#FF7170ff"/>

    <!-- Splitter tokens -->
    <SolidColorBrush x:Key="SplitterLine"       Color="#0DFFFFFF"/>
    <SolidColorBrush x:Key="SplitterLineHover"  Color="#14FFFFFF"/>

</ResourceDictionary>
