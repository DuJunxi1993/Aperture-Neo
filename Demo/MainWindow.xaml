<ui:FluentWindow x:Class="ApertureNeo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ApertureNeo.Controls;assembly="
        xmlns:behaviors="clr-namespace:ApertureNeo.Controls;assembly="
        xmlns:tree="clr-namespace:ApertureNeo.Controls.FolderTree;assembly="
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Aperture Neo · Linear"
        Width="1400" Height="900"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Foreground="{StaticResource TextPrimary}"
        Background="{StaticResource SurfaceCanvas}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyboardNavigation.DirectionalNavigation="None"
        WindowBackdropType="None"
AllowDrop="True">

<Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================== -->
        <!-- Title bar (44px, Linear thin)   -->
        <!-- ============================== -->
        <Border Grid.Row="0" x:Name="TitleBarArea" Background="{StaticResource SurfaceCanvas}"
                BorderBrush="{StaticResource BorderLineTint}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

<!-- Left: open + sidebar toggles -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <Button Style="{StaticResource LinearPrimaryButton}" Click="BtnOpen_Click" ToolTip="打开文件 (Ctrl+O)">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14"/>
                            <TextBlock Text="打开" Margin="6,0,0,0" FontSize="13" FontWeight="500"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnToggleTree" Style="{StaticResource LinearWindowButton}" Click="BtnToggleTree_Click"
                            ToolTip="显示/隐藏目录栏" Margin="6,0,0,0">
                        <ui:SymbolIcon Symbol="NavigationLocationTarget20" FontSize="16"/>
                    </Button>
                    <Button x:Name="BtnToggleThumb" Style="{StaticResource LinearWindowButton}" Click="BtnToggleThumb_Click"
                            ToolTip="显示/隐藏预览栏" Margin="2,0,0,0">
                        <ui:SymbolIcon Symbol="Grid20" FontSize="16"/>
                    </Button>
                </StackPanel>

                <!-- Center: app name -->
                <TextBlock Grid.Column="0" Grid.ColumnSpan="3" Text="Aperture Neo"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextTertiary}" FontSize="13" FontWeight="600"
                           IsHitTestVisible="False"/>

<!-- Right: overflow menu + window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                    <Button x:Name="BtnMenu" Style="{StaticResource LinearWindowButton}" Click="BtnMenu_Click"
                            ToolTip="更多选项" Margin="0,0,4,0">
                        <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="16"/>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="清除缓存">
                                    <MenuItem Header="缩略图缓存" Click="BtnClearCache_Click"/>
                                    <MenuItem Header="最近访问记录" Click="BtnClearRecent_Click"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="关于" Click="About_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Rectangle Width="1" Height="16" Fill="#14FFFFFF" Margin="4,0"/>
                    <Button Style="{StaticResource LinearWindowButton}" Click="BtnMinimize_Click" ToolTip="最小化">
                        <ui:SymbolIcon Symbol="Subtract24" FontSize="14"/>
                    </Button>
                    <Button x:Name="BtnMaximize" Style="{StaticResource LinearWindowButton}" Click="BtnMaximize_Click" ToolTip="最大化">
                        <ui:SymbolIcon x:Name="MaximizeIcon" Symbol="Square24" FontSize="14"/>
                    </Button>
                    <Button Style="{StaticResource LinearCloseButton}" Click="BtnClose_Click" ToolTip="关闭">
                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================== -->
        <!-- Main content (3 columns)       -->
        <!-- ============================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="232" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="ThumbColumn" Width="360" MinWidth="240"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

<!-- Tree panel -->
            <Border Grid.Column="0" Background="{StaticResource SurfacePanel}"
                    BorderBrush="#08FFFFFF" BorderThickness="0,0,1,0"
                    x:Name="TreePanel">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" Background="Transparent">
                        <tree:FolderTreeView x:Name="FolderTree"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{StaticResource TextPrimary}"
                                             Padding="4,8">
                            <tree:FolderTreeView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource LinearTreeIcon}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <Binding Path="IsSelected" RelativeSource="{RelativeSource AncestorType=tree:FolderItemContainer}"/>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Foreground" Value="{StaticResource SelectionFg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
<TextBlock Text="{Binding DisplayName}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
                                                    <Setter Property="FontSize" Value="13"/>
                                                    <Setter Property="FontWeight" Value="500"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="FontWeight" Value="700"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextQuat}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <Binding Path="IsSelected" RelativeSource="{RelativeSource AncestorType=tree:FolderItemContainer}"/>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Foreground" Value="{StaticResource SelectionFg}"/>
                                                            <Setter Property="FontWeight" Value="510"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </tree:FolderTreeView.ItemTemplate>
                            <tree:FolderTreeView.ItemContainerStyle>
                                <Style TargetType="tree:FolderItemContainer" BasedOn="{StaticResource LinearFolderItemContainer}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </tree:FolderTreeView.ItemContainerStyle>
                        </tree:FolderTreeView>
                    </ScrollViewer>
                    <Button Grid.Row="1" x:Name="BtnReturnToRoot" Click="BtnReturnToRoot_Click"
                            Margin="6,4" Cursor="Hand"
                            Style="{StaticResource LinearButton}"
                            HorizontalContentAlignment="Stretch"
                            Visibility="Collapsed"
                            ToolTip="返回主页">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="14"/>
                            <TextBlock Text="返回主页" Margin="6,0,0,0" FontSize="13" FontWeight="500" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" x:Name="TreeSplitter" HorizontalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="False"/>

<!-- Thumbnail panel -->
            <Border Grid.Column="2" Background="{StaticResource SurfacePanel}"
                    BorderBrush="#08FFFFFF" BorderThickness="0,0,1,0"
                    x:Name="ThumbPanel">
                <Grid>
                    <controls:ThumbnailGrid x:Name="ThumbGrid" FocusVisualStyle="{x:Null}"
                                            ItemTemplate="{StaticResource LinearThumbnailTemplate}"
                                            Padding="4,8">
                        <controls:ThumbnailGrid.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:AutoFitPanel MinItemSize="140" Spacing="4" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </controls:ThumbnailGrid.ItemsPanel>
                    </controls:ThumbnailGrid>
<!-- Empty state -->
                    <StackPanel x:Name="ThumbEmpty" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <Border Width="56" Height="56" CornerRadius="12"
                                Background="#0DFFFFFF"
                                HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="Image32" FontSize="24" Foreground="{StaticResource TextQuat}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="此文件夹没有图片" FontSize="13" FontWeight="600"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,14,0,2"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="支持 JPG、PNG、GIF、WEBP、BMP、ICO" FontSize="11" FontWeight="400"
                                   Foreground="{StaticResource TextQuat}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" x:Name="ThumbSplitter" HorizontalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="False"/>

<!-- Image viewer (full bleed). Floating overlays (floating bar, info pill,
                 status pill) are rendered as Adorners attached to ImageViewer.
                 Adorners are part of the main window's visual tree, so they
                 automatically follow window move/resize — the stable WPF pattern. -->
            <Grid Grid.Column="4" ClipToBounds="False" x:Name="ViewerColumn">
                <controls:SkiaImageViewer x:Name="ImageViewer" Panel.ZIndex="0"
                                          IsHitTestVisible="False">
                    <controls:SkiaImageViewer.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制图片路径" Click="CtxCopyPath_Click"/>
                            <MenuItem Header="在资源管理器中打开" Click="CtxOpenInExplorer_Click"/>
                            <MenuItem Header="打印" Click="CtxPrint_Click"/>
                            <MenuItem Header="设为桌面壁纸" Click="CtxSetWallpaper_Click"/>
                        </ContextMenu>
                    </controls:SkiaImageViewer.ContextMenu>
                </controls:SkiaImageViewer>
                <!-- Floating overlays use Grid + HorizontalAlignment/VerticalAlignment
                     + Margin to anchor. The Grid is hit-test transparent (no Background)
                     so empty space passes events through to the viewer; only the
                     Border children with Background brushes are clickable. -->
                <Grid x:Name="FloatingOverlayHost" Panel.ZIndex="10">
                    <Border x:Name="FloatingBarContent"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,18"
                            Background="#E60f1011" BorderBrush="#28FFFFFF" BorderThickness="1"
                            CornerRadius="{StaticResource RadiusCard}" Padding="6,4"
                            IsHitTestVisible="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnPrev" Style="{StaticResource LinearFloatingButton}"
                                    Click="BtnPrev_Click" ToolTip="上一张 (←)">
                                <ui:SymbolIcon Symbol="ChevronLeft20" FontSize="14"/>
                            </Button>
                            <TextBlock x:Name="ImageIndexInfo" Text="0/0"
                                       FontFamily="{StaticResource FontMono}" FontSize="12" FontWeight="500"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="10,0" MinWidth="48" TextAlignment="Center"/>
                            <Button x:Name="BtnNext" Style="{StaticResource LinearFloatingPrimary}"
                                    Click="BtnNext_Click" ToolTip="下一张 (→)">
                                <ui:SymbolIcon Symbol="ChevronRight20" FontSize="14"/>
                            </Button>

                            <Border Width="1" Background="#14FFFFFF" Margin="8,6"/>

                            <Button x:Name="BtnFit" Style="{StaticResource LinearFloatingButton}"
                                    Click="BtnFit_Click" ToolTip="适应 (Ctrl+0)">
                                <ui:SymbolIcon Symbol="PageFit20" FontSize="14"/>
                            </Button>
                            <TextBlock x:Name="ZoomTextBlock" Text="100%"
                                       FontFamily="{StaticResource FontMono}" FontSize="12" FontWeight="500"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center" Margin="8,0" MinWidth="44" TextAlignment="Center"
                                       MouseLeftButtonUp="ZoomTextBlock_Click" Cursor="Hand"/>
                            <Border Width="1" Background="#14FFFFFF" Margin="6,6"/>

                            <Button x:Name="BtnSlideshow" Style="{StaticResource LinearFloatingButton}"
                                    Click="BtnSlideshow_Click" ToolTip="幻灯片 (F5)">
                                <ui:SymbolIcon x:Name="SlideshowIcon" Symbol="Play20" FontSize="12"/>
                            </Button>
                            <Button x:Name="BtnFullscreen" Style="{StaticResource LinearFloatingButton}"
                                    Click="BtnFullscreen_Click" ToolTip="全屏 (Ctrl+F)" Margin="2,0,0,0">
                                <ui:SymbolIcon Symbol="FullScreenMaximize24" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border x:Name="StatusPillContent"
                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14,14,0,0"
                            Background="#CC0f1011" BorderBrush="#14FFFFFF" BorderThickness="1"
                            CornerRadius="{StaticResource RadiusPill}" Padding="10,5"
                            Visibility="Collapsed"
                            IsHitTestVisible="True">
                        <TextBlock x:Name="StatusText" FontSize="12" FontWeight="500"
                                   Foreground="{StaticResource TextTertiary}"/>
                    </Border>

                    <Border x:Name="InfoPillContent"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,14,0"
                            Background="#CC0f1011" BorderBrush="#14FFFFFF" BorderThickness="1"
                            CornerRadius="{StaticResource RadiusPill}" Padding="10,5"
                            IsHitTestVisible="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ImageInfo" Text="" FontSize="12" FontWeight="500"
                                       FontFamily="{StaticResource FontMono}"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>

</ui:FluentWindow>


