<ui:FluentWindow x:Class="ApertureNeo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ApertureNeo.Controls;assembly="
        xmlns:behaviors="clr-namespace:ApertureNeo.Controls;assembly="
        xmlns:tree="clr-namespace:ApertureNeo.Controls.FolderTree;assembly="
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Aperture Neo · Linear Demo"
        Width="1400" Height="900"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Foreground="{StaticResource TextPrimary}"
        Background="{StaticResource SurfaceCanvas}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyboardNavigation.DirectionalNavigation="None"
        WindowBackdropType="None"
        AllowDrop="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="BottomBarRow" Height="40"/>
        </Grid.RowDefinitions>

        <!-- Title bar (40px, Linear thin) -->
        <Border Grid.Row="0" x:Name="TitleBarArea" Background="{StaticResource SurfaceCanvas}"
                BorderBrush="{StaticResource BorderLineTint}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: open + sidebar toggles -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                    <Button Style="{StaticResource LinearPrimaryButton}" Click="BtnOpen_Click" ToolTip="打开文件 (Ctrl+O)">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14"/>
                            <TextBlock Text="打开" Margin="6,0,0,0" FontSize="13" FontWeight="500"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnToggleTree" Style="{StaticResource LinearWindowButton}" Click="BtnToggleTree_Click"
                            ToolTip="显示/隐藏目录栏" Margin="4,0,0,0">
                        <ui:SymbolIcon Symbol="NavigationLocationTarget20" FontSize="16"/>
                    </Button>
                    <Button x:Name="BtnToggleThumb" Style="{StaticResource LinearWindowButton}" Click="BtnToggleThumb_Click"
                            ToolTip="显示/隐藏预览栏" Margin="2,0,0,0">
                        <ui:SymbolIcon Symbol="Grid20" FontSize="16"/>
                    </Button>
                </StackPanel>

                <!-- Center: app name -->
                <TextBlock Grid.Column="0" Grid.ColumnSpan="3" Text="Aperture Neo"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextTertiary}" FontSize="13" FontWeight="600"
                           IsHitTestVisible="False"/>

                <!-- Right: overflow menu + window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnMenu" Style="{StaticResource LinearWindowButton}" Click="BtnMenu_Click"
                            ToolTip="更多选项" Margin="0,0,2,0">
                        <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="16"/>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="清除缓存">
                                    <MenuItem Header="缩略图缓存" Click="BtnClearCache_Click"/>
                                    <MenuItem Header="最近访问记录" Click="BtnClearRecent_Click"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="主题">
                                    <MenuItem x:Name="ThemeDark" Header="深色" Click="Theme_Click" Tag="dark" IsCheckable="True"/>
                                    <MenuItem x:Name="ThemeLight" Header="浅色" Click="Theme_Click" Tag="light" IsCheckable="True"/>
                                    <MenuItem x:Name="ThemeSystem" Header="跟随系统" Click="Theme_Click" Tag="system" IsCheckable="True"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="关于" Click="About_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource LinearWindowButton}" Click="BtnMinimize_Click" ToolTip="最小化">
                        <ui:SymbolIcon Symbol="Subtract24" FontSize="14"/>
                    </Button>
                    <Button x:Name="BtnMaximize" Style="{StaticResource LinearWindowButton}" Click="BtnMaximize_Click" ToolTip="最大化">
                        <ui:SymbolIcon x:Name="MaximizeIcon" Symbol="Square24" FontSize="14"/>
                    </Button>
                    <Button Style="{StaticResource LinearCloseButton}" Click="BtnClose_Click" ToolTip="关闭" Margin="0,0,4,0">
                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content (3 columns) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="220" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="ThumbColumn" Width="380" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- Tree panel -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceCanvas}" x:Name="TreePanel" Padding="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False" IsTabStop="False"
                                  Background="Transparent">
                        <tree:FolderTreeView x:Name="FolderTree"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{StaticResource TextPrimary}">
                            <tree:FolderTreeView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                        <TextBlock Text="{Binding Icon}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource LinearTreeIcon}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding DisplayName}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource LinearTreeName}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="FontWeight" Value="600"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextQuat}"/>
                                                            <Setter Property="Margin" Value="0,0,0,0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </tree:FolderTreeView.ItemTemplate>
                            <tree:FolderTreeView.ItemContainerStyle>
                                <Style TargetType="tree:FolderItemContainer" BasedOn="{StaticResource LinearFolderItemContainer}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </tree:FolderTreeView.ItemContainerStyle>
                        </tree:FolderTreeView>
                    </ScrollViewer>
                    <Button Grid.Row="1" x:Name="BtnReturnToRoot" Click="BtnReturnToRoot_Click"
                            Margin="6,4" Padding="10,5" Cursor="Hand"
                            Style="{StaticResource LinearButton}"
                            HorizontalContentAlignment="Stretch"
                            Visibility="Collapsed"
                            ToolTip="返回主页">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="14"/>
                            <TextBlock Text="返回主页" Margin="6,0,0,0" FontSize="13" FontWeight="500" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" x:Name="TreeSplitter" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="False"/>

            <!-- Thumbnail panel -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceCanvas}" x:Name="ThumbPanel" Padding="0,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent">
                    <controls:ThumbnailGrid x:Name="ThumbGrid" FocusVisualStyle="{x:Null}">
                        <controls:ThumbnailGrid.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:AutoFitPanel MinItemSize="140" Spacing="4" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </controls:ThumbnailGrid.ItemsPanel>
                        <controls:ThumbnailGrid.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border x:Name="Card"
                                            CornerRadius="{StaticResource RadiusCard}"
                                            behaviors:SquareAspectBehavior.IsEnabled="True">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#08FFFFFF"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#14FFFFFF"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <Binding Path="IsSelected" RelativeSource="{RelativeSource AncestorType=ContentControl}"/>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#FF191a1b"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="BorderBrush">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#FF7170ff"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                                            <TextBlock Text="⚠" FontSize="36" Foreground="{StaticResource StatusRed}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       ToolTip="{Binding ThumbnailErrorMessage}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasThumbnailError}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                    <TextBlock Grid.Row="1" Text="{Binding FileName}" Style="{StaticResource LinearThumbnailName}"/>
                                </Grid>
                            </DataTemplate>
                        </controls:ThumbnailGrid.ItemTemplate>
                    </controls:ThumbnailGrid>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="3" x:Name="ThumbSplitter" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="False"/>

            <!-- Image viewer -->
            <Border Grid.Column="4" Background="{StaticResource SurfaceCanvas}" ClipToBounds="False" Padding="20">
                <Border Effect="{StaticResource ShadowSubtle}">
                    <controls:SkiaImageViewer x:Name="ImageViewer">
                        <controls:SkiaImageViewer.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="复制图片路径" Click="CtxCopyPath_Click"/>
                                <MenuItem Header="在资源管理器中打开" Click="CtxOpenInExplorer_Click"/>
                                <MenuItem Header="打印" Click="CtxPrint_Click"/>
                                <MenuItem Header="设为桌面壁纸" Click="CtxSetWallpaper_Click"/>
                            </ContextMenu>
                        </controls:SkiaImageViewer.ContextMenu>
                    </controls:SkiaImageViewer>
                </Border>
            </Border>
        </Grid>

        <!-- Bottom bar (36px) -->
        <Border Grid.Row="2" x:Name="BottomBar" Background="{StaticResource SurfacePanel}"
                BorderBrush="{StaticResource BorderLineTint}" BorderThickness="0,1,0,0"
                Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" MinWidth="280" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="就绪" VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource TextTertiary}" FontWeight="500">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tag, ElementName=StatusText}" Value="error">
                                        <Setter Property="Foreground" Value="{StaticResource StatusRed}"/>
                                        <Setter Property="FontWeight" Value="600"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock x:Name="ImageInfo" Text="" VerticalAlignment="Center" FontSize="12"
                               FontWeight="500" Foreground="{StaticResource TextQuat}" Margin="16,0,0,0"/>
                    <TextBlock x:Name="ImageIndexInfo" Text="" VerticalAlignment="Center" FontSize="12"
                               FontWeight="500" Foreground="{StaticResource TextQuat}" Margin="12,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button x:Name="BtnPrev" Style="{StaticResource LinearPrimaryButton}" Click="BtnPrev_Click" ToolTip="上一张 (←)">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ChevronLeft20" FontSize="14"/>
                            <TextBlock Text="上一张" Margin="6,0,0,0" FontSize="13" FontWeight="500"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnNext" Style="{StaticResource LinearPrimaryButton}" Click="BtnNext_Click" Margin="6,0,0,0" ToolTip="下一张 (→)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="下一张" FontSize="13" FontWeight="500"/>
                            <ui:SymbolIcon Symbol="ChevronRight20" FontSize="14" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource LinearButton}" Click="BtnFit_Click" ToolTip="适应 (Ctrl+0)">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="PageFit20" FontSize="14"/>
                            <TextBlock Text="适应" Margin="6,0,0,0" FontSize="13" FontWeight="500"/>
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="ZoomTextBlock" Text="100%" Foreground="{StaticResource TextPrimary}"
                               FontFamily="{StaticResource FontMono}" FontSize="12" FontWeight="500"
                               VerticalAlignment="Center" Margin="10,0" MinWidth="48" TextAlignment="Center"
                               MouseLeftButtonUp="ZoomTextBlock_Click" Cursor="Hand"/>
                    <Border Width="1" Background="{StaticResource BorderSubtle}" Margin="4,8"/>
                    <Button x:Name="BtnSlideshow" Style="{StaticResource LinearButton}" Click="BtnSlideshow_Click" Margin="4,0,0,0" ToolTip="幻灯片 (F5)">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon x:Name="SlideshowIcon" Symbol="Play20" FontSize="12"/>
                            <TextBlock x:Name="SlideshowText" Text="幻灯片" FontSize="13" FontWeight="500" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnFullscreen" Style="{StaticResource LinearButton}" Click="BtnFullscreen_Click" Margin="4,0,0,0" ToolTip="全屏 (Ctrl+F)">
                        <ui:SymbolIcon Symbol="FullScreenMaximize24" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
