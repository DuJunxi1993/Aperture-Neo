<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Linear-styled MenuItem.
         Uses the standard WPF MenuItem template structure (per MSDN):
         PART_Popup MUST be present and bound via TemplateBinding IsSubmenuOpen
         for submenus to open. Omitting PART_Popup causes NullReferenceException
         when the user hovers a parent MenuItem. -->
    <Style x:Key="LinearMenuItem" TargetType="MenuItem">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="500"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusStd}"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemIconColumnGroup"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemIGTColumnGroup"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon column (left) -->
                            <ContentPresenter Grid.Column="0"
                                              x:Name="Icon"
                                              ContentSource="Icon"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"
                                              Width="16" Height="16"/>

                            <!-- Header column (middle) -->
                            <ContentPresenter Grid.Column="1"
                                              x:Name="HeaderHost"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="0,0,16,0"
                                              HorizontalAlignment="Left"/>

                            <!-- Submenu arrow indicator (right, only for items with submenus) -->
                            <TextBlock Grid.Column="2"
                                       x:Name="IGTSubmenuIndicator"
                                       Text="›"
                                       FontSize="14"
                                       Foreground="{StaticResource TextQuat}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="6,0,0,0"
                                       Visibility="Collapsed"/>

                            <!-- Submenu popup — bound to TemplatedParent.IsSubmenuOpen.
                                 MUST use TemplateBinding (not RelativeSource) for proper
                                 two-way synchronization. -->
                            <Popup Grid.Column="0" Grid.ColumnSpan="3"
                                   x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Right"
                                   HorizontalOffset="-2"
                                   VerticalOffset="-4"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="SubmenuBorder"
                                        Background="{StaticResource SurfaceElevated}"
                                        BorderBrush="{StaticResource BorderStandard}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusStd}"
                                        Padding="6">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" Color="Black"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                        Grid.IsSharedSizeScope="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Show submenu arrow for items that have sub-items -->
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="IGTSubmenuIndicator" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BtnBgHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Linear-styled Separator -->
    <Style x:Key="LinearSeparator" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="6,4"/>
    </Style>

    <!-- Linear-styled ContextMenu container.
         ItemContainerStyle is NOT set here — the implicit Style below applies
         LinearMenuItem automatically. Double-application of the style causes
         NullReferenceException when submenus open. -->
    <Style x:Key="LinearContextMenu" TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource SurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderStandard}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="Effect" Value="{StaticResource ShadowDialog}"/>
        <Style.Resources>
            <Style TargetType="ScrollViewer" BasedOn="{StaticResource LinearScrollViewer}"/>
        </Style.Resources>
    </Style>

    <!-- Apply globally -->
    <Style TargetType="ContextMenu" BasedOn="{StaticResource LinearContextMenu}"/>
    <Style TargetType="MenuItem" BasedOn="{StaticResource LinearMenuItem}"/>
    <Style TargetType="Separator" BasedOn="{StaticResource LinearSeparator}"/>

</ResourceDictionary>