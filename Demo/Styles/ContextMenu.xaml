<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Linear-styled MenuItem — minimal custom template that ADDS
         Linear colors while keeping WPF's default MenuItem structure intact.

         We use a SINGLE template (not a separate SubmenuHeaderTemplateKey)
         to avoid the trap where one template's PART_Popup points to a
         different template's Grid layout. The PART_Popup is included in
         this single template; for leaf items (no children) the Popup is
         simply never opened because IsSubmenuOpen stays false.

         This is a known-stable WPF pattern; the more elaborate
         "SubmenuHeaderTemplateKey + default template" split is what causes
         the hover crashes. -->
    <Style x:Key="LinearMenuItem" TargetType="MenuItem">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="500"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusStd}"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemIconColumnGroup"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemIGTColumnGroup"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon ContentPresenter. No explicit Width/Height — the cell
                                 collapses to 0 when no Icon is set, eliminating the
                                 empty vertical strip on the left of every leaf
                                 menu item. -->
                            <ContentPresenter Grid.Column="0"
                                              x:Name="Icon"
                                              ContentSource="Icon"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"/>

                            <ContentPresenter Grid.Column="1"
                                              x:Name="HeaderHost"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="0,0,16,0"
                                              HorizontalAlignment="Left"/>

                            <!-- Submenu arrow indicator — only shown when this item has children -->
                            <TextBlock Grid.Column="2"
                                       x:Name="IGTSubmenuIndicator"
                                       Text="›"
                                       FontSize="14"
                                       Foreground="{StaticResource TextQuat}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="6,0,0,0"
                                       Visibility="Collapsed"/>

                            <!-- PART_Popup with TemplateBinding IsSubmenuOpen.
                                 For leaf items this Popup is in the template but
                                 never opens (IsSubmenuOpen stays false). For parent
                                 items, IsSubmenuOpen becomes true on hover and the
                                 Popup shows the child ItemsPresenter. -->
                            <Popup x:Name="PART_Popup"
                                   Grid.Column="0" Grid.ColumnSpan="3"
                                   AllowsTransparency="True"
                                   Placement="Right"
                                   HorizontalOffset="-2"
                                   VerticalOffset="-4"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource SurfaceElevated}"
                                        BorderBrush="{StaticResource BorderStandard}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusStd}"
                                        Padding="6">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" Color="Black"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                        Grid.IsSharedSizeScope="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Show the › arrow only when this item has children. -->
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="IGTSubmenuIndicator" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BtnBgHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Linear-styled Separator -->
    <Style x:Key="LinearSeparator" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="6,4"/>
    </Style>

    <!-- Linear-styled ContextMenu container.
         BorderThickness=0 — the BorderBrush="#14FFFFFF" was appearing as a
         thin white vertical bar on the left of the menu against the dark
         canvas, looking like an unwanted overlay. Removing the border keeps
         the rounded Background shape (set on the Popup's inner Border)
         as the sole visual edge. -->
    <Style x:Key="LinearContextMenu" TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource SurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="Effect" Value="{StaticResource ShadowDialog}"/>
        <Style.Resources>
            <Style TargetType="ScrollViewer" BasedOn="{StaticResource LinearScrollViewer}"/>
        </Style.Resources>
    </Style>

    <!-- Apply globally -->
    <Style TargetType="ContextMenu" BasedOn="{StaticResource LinearContextMenu}"/>
    <Style TargetType="MenuItem" BasedOn="{StaticResource LinearMenuItem}"/>
    <Style TargetType="Separator" BasedOn="{StaticResource LinearSeparator}"/>

</ResourceDictionary>