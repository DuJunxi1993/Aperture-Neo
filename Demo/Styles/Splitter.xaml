<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Linear GridSplitter: 8px transparent hit zone + 1px semi-transparent line, animated expand on hover -->
    <Style TargetType="GridSplitter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridSplitter">
                    <Grid Background="Transparent" SnapsToDevicePixels="True" Width="8">
                        <Rectangle x:Name="Line" Width="1"
                                   Fill="{StaticResource SplitterLine}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Stretch"
                                   SnapsToDevicePixels="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- IsMouseOver: animate width (DoubleAnimation is fine on a
                             double property), swap Fill via Setter (ColorAnimation
                             would crash on the frozen resource brush). -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Line" Property="Width" Value="2"/>
                            <Setter TargetName="Line" Property="Fill">
                                <Setter.Value>
                                    <SolidColorBrush Color="#14FFFFFF"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="False">
                            <Setter TargetName="Line" Property="Width" Value="1"/>
                            <Setter TargetName="Line" Property="Fill">
                                <Setter.Value>
                                    <SolidColorBrush Color="#0DFFFFFF"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>