<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="clr-namespace:ApertureNeo.Controls;assembly="
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:models="clr-namespace:ApertureNeo.Models;assembly="
                    xmlns:controls="clr-namespace:ApertureNeo.Controls;assembly=">

    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- ============================================================ -->
    <!-- Backwards-compat resource overrides                            -->
    <!-- Consumed by ThumbnailItem.UpdateVisual() (code-behind lookup)  -->
    <!-- ============================================================ -->
    <SolidColorBrush x:Key="ThumbnailSelectedBg"  Color="#FF191a1b"/>
    <SolidColorBrush x:Key="ThumbnailHoverBg"     Color="#FF28282c"/>
    <SolidColorBrush x:Key="ThumbnailBorder"      Color="#FF7170ff"/>
    <SolidColorBrush x:Key="TreeItemHoverBg"      Color="#FF28282c"/>
    <SolidColorBrush x:Key="TreeItemSelectedBg"   Color="#FF191a1b"/>
    <SolidColorBrush x:Key="TreeItemSelectedFg"   Color="#FFf7f8f8"/>
    <SolidColorBrush x:Key="WindowButtonHoverBg"  Color="#0DFFFFFF"/>
    <SolidColorBrush x:Key="WindowButtonPressedBg" Color="#0DFFFFFF"/>
    <SolidColorBrush x:Key="HoverBg"    Color="#0DFFFFFF"/>
    <SolidColorBrush x:Key="PressedBg"  Color="#0AFFFFFF"/>
    <SolidColorBrush x:Key="SelectionBg" Color="#FF191a1b"/>
    <SolidColorBrush x:Key="SelectionBorder" Color="#FF7170ff"/>

    <!-- ============================================================ -->
    <!-- Linear-themed ScrollBar (subtle, draggable)                   -->
    <!-- ============================================================ -->
    <Style x:Key="LinearScrollBarThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="#28FFFFFF" CornerRadius="3"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LinearScrollBarPageButton" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Rectangle Fill="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LinearVerticalScrollBar" TargetType="ScrollBar">
        <Setter Property="Width" Value="10"/>
        <Setter Property="MinWidth" Value="10"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Track Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource LinearScrollBarThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand"
                                              Style="{StaticResource LinearScrollBarPageButton}"/>
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand"
                                              Style="{StaticResource LinearScrollBarPageButton}"/>
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="10"/>
                <Setter Property="MinHeight" Value="10"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{TemplateBinding Background}">
                                <Track Name="PART_Track">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource LinearScrollBarThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageRightCommand"
                                                      Style="{StaticResource LinearScrollBarPageButton}"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                      Style="{StaticResource LinearScrollBarPageButton}"/>
                                    </Track.DecreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LinearScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ScrollContentPresenter Grid.Column="0" Content="{TemplateBinding Content}"
                                                Margin="{TemplateBinding Padding}"/>
                        <ScrollBar Grid.Column="1" Name="PART_VerticalScrollBar"
                                   Orientation="Vertical"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Style="{StaticResource LinearVerticalScrollBar}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollViewer" BasedOn="{StaticResource LinearScrollViewer}"/>

    <!-- ============================================================ -->
    <!-- Thumbnail card text label                                     -->
    <!-- ============================================================ -->
    <Style x:Key="LinearThumbnailName" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="500"/>
        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
        <Setter Property="MaxWidth" Value="160"/>
    </Style>

    <!-- ============================================================ -->
    <!-- Thumbnail card template (used inline in MainWindow.xaml)      -->
    <!-- The wrapping ThumbnailItem (ContentControl) carries           -->
    <!-- IsSelected; this template reacts to it.                       -->
    <!-- ============================================================ -->
    <DataTemplate x:Key="LinearThumbnailTemplate" DataType="{x:Type models:ImageItem}">
        <Grid Margin="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="Card"
                    CornerRadius="{StaticResource RadiusCard}"
                    behaviors:SquareAspectBehavior.IsEnabled="True"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource CardBg}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
                        <Style.Triggers>
                            <!-- Hover state (via ancestor ThumbnailItem.IsMouseOver) -->
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <Binding Path="IsMouseOver"
                                             RelativeSource="{RelativeSource AncestorType=controls:ThumbnailItem}"/>
                                </DataTrigger.Binding>
                                <Setter Property="Background" Value="{StaticResource CardBgHover}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource CardBorderHover}"/>
                            </DataTrigger>
                            <!-- Selected state -->
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <Binding Path="IsSelected"
                                             RelativeSource="{RelativeSource AncestorType=controls:ThumbnailItem}"/>
                                </DataTrigger.Binding>
                                <Setter Property="Background" Value="{StaticResource CardBgSelected}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource CardBorderSelected}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                    <!-- Error state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="#CC0f1011"
                                Visibility="{Binding HasThumbnailError, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="⚠" FontSize="24" Foreground="{StaticResource StatusRed}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="加载失败" FontSize="11" FontWeight="500"
                                   Foreground="{StaticResource TextTertiary}"
                                   Margin="0,2,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1" Text="{Binding FileName}" Style="{StaticResource LinearThumbnailName}"/>
        </Grid>
    </DataTemplate>

</ResourceDictionary>