<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:tree="clr-namespace:ApertureNeo.Controls.FolderTree;assembly=">

    <!-- Linear FolderItemContainer: full template with IsSelected trigger, animated hover, in-card selection bar -->
    <Style x:Key="LinearFolderItemContainer" TargetType="tree:FolderItemContainer">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="tree:FolderItemContainer">
                    <Grid Margin="8,2">
                        <Border x:Name="Row"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource RadiusStd}">
                            <Grid>
                                <!-- Selection bar: 2.5px brand indigo, flush-left, no indent -->
                                <Border x:Name="SelectionBar"
                                        Width="2.5"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Margin="0,6,0,6"
                                        Background="{StaticResource SelectionBar}"
                                        Opacity="0"
                                        CornerRadius="1"/>
                                <ContentPresenter Margin="18,8,12,8" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </DataTrigger>
                        <!-- Hover (non-selected): subtle white wash -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Row"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#0DFFFFFF" Duration="{StaticResource MotionMicro}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Row"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#00000000" Duration="{StaticResource MotionMicro}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- Selected: multi-signal activation - indigo tint bg + accent glow + bar -->
                        <Trigger Property="IsSelected" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Row"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#1A5e6ad2" Duration="{StaticResource MotionStandard}"/>
                                        <DoubleAnimation Storyboard.TargetName="SelectionBar"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="{StaticResource MotionStandard}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Row"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#00000000" Duration="{StaticResource MotionStandard}"/>
                                        <DoubleAnimation Storyboard.TargetName="SelectionBar"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="{StaticResource MotionStandard}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <!-- Indigo outer glow to lift the row out of the dark canvas -->
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.45" Color="#FF5e6ad2"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Section header label style -->
    <Style x:Key="LinearSectionHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="700"/>
        <Setter Property="Foreground" Value="{StaticResource TextQuat}"/>
        <Setter Property="Margin" Value="18,20,0,10"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <!-- Linear icon style for tree row icons -->
    <Style x:Key="LinearTreeIcon" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="MinWidth" Value="16"/>
    </Style>

    <!-- Tree row display name -->
    <Style x:Key="LinearTreeName" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="500"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <!-- Empty hint text -->
    <Style x:Key="LinearEmptyHint" TargetType="TextBlock" BasedOn="{StaticResource LinearTreeName}">
        <Setter Property="Foreground" Value="{StaticResource TextQuat}"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="FontWeight" Value="400"/>
    </Style>

</ResourceDictionary>