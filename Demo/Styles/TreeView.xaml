<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:tree="clr-namespace:ApertureNeo.Controls.FolderTree;assembly=">

    <Style x:Key="LinearTreeItemContainer" TargetType="{x:Type ContentControl}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">
                    <Grid>
                        <!-- Left selection bar (2px brand accent when selected) -->
                        <Border x:Name="SelectionBar"
                                Width="2"
                                HorizontalAlignment="Left"
                                Margin="-2,0,0,0"
                                Background="{StaticResource BrandAccent}"
                                Visibility="Collapsed"/>
                        <Border x:Name="Row"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource RadiusStd}"
                                Margin="4,1,4,1"
                                Padding="0,4">
                            <ContentPresenter Margin="10,0"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="{StaticResource SurfaceHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Strongly-typed style for FolderItemContainer: full template with IsSelected trigger -->
    <Style x:Key="LinearFolderItemContainer" TargetType="tree:FolderItemContainer">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="tree:FolderItemContainer">
                    <Grid>
                        <Border x:Name="SelectionBar"
                                Width="2"
                                HorizontalAlignment="Left"
                                Margin="-2,0,0,0"
                                Background="{StaticResource BrandAccent}"
                                Visibility="Collapsed"/>
                        <Border x:Name="Row"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource RadiusStd}"
                                Margin="4,1,4,1"
                                Padding="0,4">
                            <ContentPresenter Margin="10,0"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </DataTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Row" Property="Background" Value="{StaticResource SurfaceHover}"/>
                        </MultiTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="{StaticResource SurfaceElevated}"/>
                            <Setter TargetName="SelectionBar" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Section header label style -->
    <Style x:Key="LinearSectionHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="600"/>
        <Setter Property="Foreground" Value="{StaticResource TextQuat}"/>
        <Setter Property="Margin" Value="14,12,0,4"/>
    </Style>

    <!-- Linear icon style for tree row icons -->
    <Style x:Key="LinearTreeIcon" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <!-- Tree row display name -->
    <Style x:Key="LinearTreeName" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="500"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <!-- Empty hint text -->
    <Style x:Key="LinearEmptyHint" TargetType="TextBlock" BasedOn="{StaticResource LinearTreeName}">
        <Setter Property="Foreground" Value="{StaticResource TextQuat}"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="FontWeight" Value="400"/>
    </Style>

</ResourceDictionary>
