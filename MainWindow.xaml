<ui:FluentWindow x:Class="ApertureNeo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ApertureNeo.Controls"
        xmlns:behaviors="clr-namespace:ApertureNeo.Controls"
        xmlns:tree="clr-namespace:ApertureNeo.Controls.FolderTree"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Aperture Neo"
        Width="1400" Height="900"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Foreground="{DynamicResource WindowFg}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyboardNavigation.DirectionalNavigation="None"
        WindowBackdropType="None"
        Background="{DynamicResource WindowBg}"
        AllowDrop="True">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OpenButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBlueHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBluePressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource WindowButtonHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource WindowButtonPressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource CloseHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ClosePressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent" SnapsToDevicePixels="True">
                            <Rectangle x:Name="Line" Width="1"
                                       Fill="{DynamicResource SplitterLine}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Stretch"
                                       SnapsToDevicePixels="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Line" Property="Width" Value="2"/>
                                <Setter TargetName="Line" Property="Fill" Value="{DynamicResource SelectionBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="BottomBarRow" Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" x:Name="TitleBarArea" Background="{DynamicResource TitleBarBg}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Button Style="{StaticResource OpenButton}" Click="BtnOpen_Click" ToolTip="打开文件 (Ctrl+O)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="打开" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnToggleTree" Style="{StaticResource ModernButton}" Click="BtnToggleTree_Click"
                            ToolTip="显示/隐藏目录栏" Padding="8,6" Margin="8,0,0,0">
                        <TextBlock x:Name="TreeIcon" Text="目录" FontSize="12"/>
                    </Button>
                    <Button x:Name="BtnToggleThumb" Style="{StaticResource ModernButton}" Click="BtnToggleThumb_Click"
                            ToolTip="显示/隐藏预览栏" Padding="8,6" Margin="4,0,0,0">
                        <TextBlock x:Name="ThumbIcon" Text="预览" FontSize="12"/>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="0" Grid.ColumnSpan="3" Text="Aperture Neo" VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" FontSize="14" FontWeight="SemiBold"
                           IsHitTestVisible="False"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnMenu" Style="{StaticResource ModernButton}" Click="BtnMenu_Click"
                            ToolTip="更多选项" Padding="6,6" Margin="0,0,4,0">
                        <TextBlock Text="⋮" FontSize="16"/>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="清除缓存">
                                    <MenuItem Header="缩略图缓存" Click="BtnClearCache_Click"/>
                                    <MenuItem Header="最近访问记录" Click="BtnClearRecent_Click"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="主题">
                                    <MenuItem x:Name="ThemeDark" Header="深色" Click="Theme_Click" Tag="dark"/>
                                    <MenuItem x:Name="ThemeLight" Header="浅色" Click="Theme_Click" Tag="light"/>
                                    <MenuItem x:Name="ThemeSystem" Header="跟随系统" Click="Theme_Click" Tag="system"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="关于" Click="About_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource WindowButton}" Click="BtnMinimize_Click">
                        <TextBlock Text="&#x2500;" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                    </Button>
                    <Button x:Name="BtnMaximize" Style="{StaticResource WindowButton}" Click="BtnMaximize_Click">
                        <TextBlock x:Name="MaximizeIcon" Text="&#x25A1;" FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                    </Button>
                    <Button Style="{StaticResource CloseButton}" Click="BtnClose_Click">
                        <TextBlock Text="&#x2715;" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="200" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="ThumbColumn" Width="400" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource PanelBg}" x:Name="TreePanel" Padding="4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False" IsTabStop="False">
                        <tree:FolderTreeView x:Name="FolderTree"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource TextPrimary}">
                            <tree:FolderTreeView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" FontSize="{Binding IconFontSize}"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontWeight="{Binding DisplayFontWeight}"
                                                   MaxWidth="220" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding DisplayName}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                            <Setter Property="FontSize" Value="11"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </tree:FolderTreeView.ItemTemplate>
                            <tree:FolderTreeView.ItemContainerStyle>
                                <Style TargetType="tree:FolderItemContainer">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="tree:FolderItemContainer">
                                                <StackPanel>
                                                    <Border x:Name="Separator" Height="1" Margin="0,6,0,6"
                                                            Background="Transparent"
                                                            Visibility="Collapsed"/>
                                                    <Border x:Name="Row" Background="{TemplateBinding Background}"
                                                            CornerRadius="6" Padding="4,3">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                                        <Setter TargetName="Separator" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="Separator" Property="Background" Value="{DynamicResource BorderColor}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsFirstSection}" Value="True">
                                                        <Setter TargetName="Separator" Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource TreeItemSelectedBg}"/>
                                        </DataTrigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource TreeItemHoverBg}"/>
                                        </MultiTrigger>
                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                            <Setter Property="Cursor" Value="Arrow"/>
                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </tree:FolderTreeView.ItemContainerStyle>
                        </tree:FolderTreeView>
                    </ScrollViewer>
                    <Button Grid.Row="1" x:Name="BtnReturnToRoot" Click="BtnReturnToRoot_Click"
                            Margin="0,2,0,4" Padding="8,4" Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Background="Transparent" BorderThickness="0"
                            Visibility="Collapsed"
                            ToolTip="返回主页">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Row" Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="4,3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏠" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="返回主页" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Row" Property="Background" Value="{DynamicResource TreeItemHoverBg}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Row" Property="Background" Value="{DynamicResource TreeItemSelectedBg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" x:Name="TreeSplitter" Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource SplitterBg}" ShowsPreview="False"/>

            <Border Grid.Column="2" Background="{DynamicResource PanelBg}" x:Name="ThumbPanel" Padding="4,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <controls:ThumbnailGrid x:Name="ThumbGrid" FocusVisualStyle="{x:Null}">
                        <controls:ThumbnailGrid.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:AutoFitPanel MinItemSize="150" Spacing="6" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </controls:ThumbnailGrid.ItemsPanel>
                        <controls:ThumbnailGrid.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="3">
                                    <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ContentControl}}"
                                            BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ContentControl}}"
                                            BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ContentControl}}"
                                            CornerRadius="8" behaviors:SquareAspectBehavior.IsEnabled="True">
                                        <Grid>
                                            <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                                            <TextBlock Text="⚠" FontSize="48" Foreground="{DynamicResource ErrorText}" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="{Binding ThumbnailErrorMessage}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasThumbnailError}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" TextAlignment="Center" ToolTip="{Binding FileName}"/>
                                </StackPanel>
                            </DataTemplate>
                        </controls:ThumbnailGrid.ItemTemplate>
                    </controls:ThumbnailGrid>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="3" x:Name="ThumbSplitter" Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource SplitterBg}" ShowsPreview="False"/>

            <Border Grid.Column="4" Background="{DynamicResource PanelBg}" ClipToBounds="False" Padding="20">
                <Border Effect="{DynamicResource ImageShadow}">
                    <controls:SkiaImageViewer x:Name="ImageViewer">
                        <controls:SkiaImageViewer.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="复制图片路径" Click="CtxCopyPath_Click"/>
                                <MenuItem Header="在资源管理器中打开" Click="CtxOpenInExplorer_Click"/>
                                <MenuItem Header="打印" Click="CtxPrint_Click"/>
                                <MenuItem Header="设为桌面壁纸" Click="CtxSetWallpaper_Click"/>
                            </ContextMenu>
                        </controls:SkiaImageViewer.ContextMenu>
                    </controls:SkiaImageViewer>
                </Border>
            </Border>
        </Grid>

        <Border Grid.Row="2" x:Name="BottomBar" Background="{DynamicResource BottomBarBg}" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" MinWidth="280">
                    <TextBlock x:Name="StatusText" Text="就绪" VerticalAlignment="Center" FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tag, ElementName=StatusText}" Value="error">
                                        <Setter Property="Foreground" Value="{DynamicResource ErrorText}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock x:Name="ImageInfo" Text="" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="20,0,0,0"/>
                    <TextBlock x:Name="ImageIndexInfo" Text="" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="16,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnPrev" Style="{StaticResource OpenButton}" Click="BtnPrev_Click" ToolTip="上一张 (←)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◀" FontSize="11" Foreground="White"/>
                            <TextBlock Text="上一张" FontSize="12" Foreground="White" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnNext" Style="{StaticResource OpenButton}" Click="BtnNext_Click" Margin="4,0,0,0" ToolTip="下一张 (→)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="下一张" FontSize="12" Foreground="White"/>
                            <TextBlock Text="▶" FontSize="11" Foreground="White" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource ModernButton}" Click="BtnFit_Click" Padding="10,6" ToolTip="适应 (Ctrl+0)">
                        <TextBlock Text="适应" FontSize="12"/>
                    </Button>
                    <TextBlock x:Name="ZoomTextBlock" Text="100%" Foreground="{DynamicResource TextPrimary}" FontSize="12" VerticalAlignment="Center" Margin="12,0" MinWidth="50" TextAlignment="Center" MouseLeftButtonUp="ZoomTextBlock_Click" Cursor="Hand"/>
                    <Border Width="1" Background="{DynamicResource BorderColor}" Margin="8,4"/>
                    <Button x:Name="BtnSlideshow" Style="{StaticResource ModernButton}" Click="BtnSlideshow_Click" Padding="10,6" ToolTip="幻灯片 (F5)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SlideshowIcon" Text="▶" FontSize="11"/>
                            <TextBlock x:Name="SlideshowText" Text="幻灯片" FontSize="12" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnFullscreen" Style="{StaticResource ModernButton}" Click="BtnFullscreen_Click" Padding="10,6" Margin="4,0,0,0" ToolTip="全屏 (Ctrl+F)">
                        <TextBlock Text="⛶" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
