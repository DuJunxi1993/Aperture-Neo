<ui:FluentWindow x:Class="ApertureNeo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ApertureNeo.Controls;assembly="
        xmlns:behaviors="clr-namespace:ApertureNeo.Controls;assembly="
        xmlns:tree="clr-namespace:ApertureNeo.Controls.FolderTree;assembly="
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Aperture Neo · Linear"
        Width="1400" Height="900"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Foreground="{StaticResource TextPrimary}"
        Background="{StaticResource SurfaceCanvas}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyboardNavigation.DirectionalNavigation="None"
        WindowBackdropType="None"
        WindowStyle="SingleBorderWindow"
AllowDrop="True">

    <!-- WindowChrome.WindowChrome: customize the non-client area so
         the OS draws a fully dark border that matches our Linear
         canvas. Without this, the FluentWindow falls back to the
         default Aero chrome which renders a 1px system-color line
         around the client area.
         - CaptionHeight=44 lets the top row drag the window.
         - ResizeBorderThickness=0 removes the OS edge-resize zone
           so the TreePanel sits flush against the window's left
           edge (matching the linear chrome-less look). Window is
           only resizable via the bottom-right corner; panes resize
           via their own GridSplitter handles.
         - GlassFrameThickness=0 disables the Aero glass frame.
         - UseAeroCaptionButtons=True keeps the min/max/close
           buttons in the upper right. -->
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="True"/>
    </WindowChrome.WindowChrome>

<Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================== -->
        <!-- Title bar (44px, Linear thin)   -->
        <!-- ============================== -->
        <Border Grid.Row="0" x:Name="TitleBarArea" Background="{StaticResource SurfaceCanvas}"
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

<!-- Left: open + sidebar toggles. The 打开 button is now a flat
         ghost-with-icon (not a primary CTA) so the title bar reads
         quieter; the BrandPrimary is reserved for actual actions. -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                    <Button Style="{StaticResource LinearPrimaryButton}" Click="BtnOpen_Click"
                            Margin="0,0,2,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="12"/>
                            <TextBlock Text="打开" Margin="5,0,0,0" FontSize="12" FontWeight="600"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnToggleTree" Style="{StaticResource LinearWindowButton}" Click="BtnToggleTree_Click"
                            Margin="2,0,0,0">
                        <ui:SymbolIcon Symbol="NavigationLocationTarget20" FontSize="16"/>
                    </Button>
                    <Button x:Name="BtnToggleThumb" Style="{StaticResource LinearWindowButton}" Click="BtnToggleThumb_Click"
                            Margin="2,0,0,0">
                        <ui:SymbolIcon Symbol="Grid20" FontSize="16"/>
                    </Button>
                </StackPanel>

                <!-- Center: app name. Bumped to 15px / 600 weight, and
                     placed in the center column for proper centering
                     (was ColumnSpan=3 which misaligns when left/right
                     widths differ). -->
                <TextBlock Grid.Column="1" Text="Aperture Neo"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}" FontSize="15" FontWeight="700"
                           IsHitTestVisible="False"/>

<!-- Right: overflow menu + window controls.
         The vertical separator between ⋮ and the window controls
         is now a 1px Linear hairline. The window buttons themselves
         are 40×40 (was 32×32) per Q5. -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button x:Name="BtnMenu" Style="{StaticResource LinearWindowButton}" Click="BtnMenu_Click"
                            Margin="0,0,2,0">
                        <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="16"/>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="清除缓存" Tag="destructive">
                                    <MenuItem Header="缩略图缓存" Click="BtnClearCache_Click"/>
                                    <MenuItem Header="最近访问记录" Click="BtnClearRecent_Click"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="关于" Click="About_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderStandard}" Margin="6,0"/>
                    <Button Style="{StaticResource LinearWindowButton}" Click="BtnMinimize_Click">
                        <ui:SymbolIcon Symbol="Subtract24" FontSize="14"/>
                    </Button>
                    <Button x:Name="BtnMaximize" Style="{StaticResource LinearWindowButton}" Click="BtnMaximize_Click">
                        <ui:SymbolIcon x:Name="MaximizeIcon" Symbol="Square24" FontSize="14"/>
                    </Button>
                    <Button Style="{StaticResource LinearCloseButton}" Click="BtnClose_Click">
                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================== -->
        <!-- Main content (3 columns)       -->
        <!-- ============================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="232" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="ThumbColumn" Width="400" MinWidth="160"/>
                <ColumnDefinition Width="6"/>
                <!-- Round 57: added back the ThumbSplitter so the
                     user can resize the thumbnail column width. The
                     splitter sits in its own 6px column between the
                     thumb panel and the viewer, making it easy to
                     grab without overlapping either panel's content
                     area. -->
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

<!-- Tree panel. Background uses SurfaceCanvas (the same off-white
                 as the viewer column) so the tree and viewer columns
                 read as the same "outer shell" — the thumbnail column
                 is the only mid-grey middle panel. The user wants
                 the tree and viewer to share a color so the layout
                 reads as: outer shell (tree + viewer, off-white) /
                 middle panel (thumbnail column, mid-grey). No
                 hairline border on the right edge — the splitter
                 column to the right carries the seam color instead
                 so the seam is invisible at rest. -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceElevated}"
                    x:Name="TreePanel">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Floating "back" chip — visible only when in
                         drill mode (deeper folder open). Sits above
                         the tree, styled like a floating chip with
                         the same shadow as the floating nav bar. -->
                    <Button Grid.Row="0" x:Name="BtnTreeBack" Click="BtnTreeBack_Click"
                            Margin="8,8,8,4" Cursor="Hand"
                            Style="{StaticResource LinearFloatingChip}"
                            HorizontalAlignment="Left"
                            Visibility="Collapsed"
                            ToolTip="返回上一层">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="13"/>
                            <TextBlock Text="返回上一层" Margin="6,0,0,0" FontSize="12" FontWeight="600" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <ScrollViewer Grid.Row="1" Background="Transparent"
                                  VerticalScrollBarVisibility="Auto">
                        <tree:FolderTreeView x:Name="FolderTree"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{StaticResource TextPrimary}"
                                             Padding="0,4">
                            <tree:FolderTreeView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource LinearTreeIcon}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <Binding Path="IsMouseOver"
                                                                         RelativeSource="{RelativeSource AncestorType=tree:FolderItemContainer}"/>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <Binding Path="IsSelected" RelativeSource="{RelativeSource AncestorType=tree:FolderItemContainer}"/>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Foreground" Value="{StaticResource SelectionFg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding DisplayName}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
                                                    <Setter Property="FontSize" Value="13"/>
                                                    <Setter Property="FontWeight" Value="500"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                                            <Setter Property="FontSize" Value="11"/>
                                                            <Setter Property="FontWeight" Value="600"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <Binding Path="IsSelected" RelativeSource="{RelativeSource AncestorType=tree:FolderItemContainer}"/>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Foreground" Value="{StaticResource SelectionFg}"/>
                                                            <Setter Property="FontWeight" Value="600"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </tree:FolderTreeView.ItemTemplate>
                            <tree:FolderTreeView.ItemContainerStyle>
                                <Style TargetType="tree:FolderItemContainer" BasedOn="{StaticResource LinearFolderItemContainer}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </tree:FolderTreeView.ItemContainerStyle>
                        </tree:FolderTreeView>
                    </ScrollViewer>
                    <Button Grid.Row="2" x:Name="BtnReturnToRoot" Click="BtnReturnToRoot_Click"
                            Margin="8,6,8,8" Cursor="Hand"
                            Style="{StaticResource LinearFloatingChip}"
                            HorizontalAlignment="Left"
                            Visibility="Collapsed"
                            ToolTip="返回主页">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="13"/>
                            <TextBlock Text="返回主页" Margin="6,0,0,0" FontSize="12" FontWeight="600" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" x:Name="TreeSplitter" HorizontalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="False"/>

<!-- Thumbnail panel. Background is Transparent so the panel
                 takes on the MainWindow's SurfaceCanvas tone — keeps
                 the three-column layout looking like two shells
                 (tree + viewer, both off-white) with a single
                 tinted "middle band" in the thumbnail column. The
                 actual mid-grey band comes from the image cards
                 themselves (CardBg=#FFFFFF on the transparent
                 panel reads as a row of white tiles floating on
                 the off-white shell).
                 BorderThickness=0 strips the ListBox's default 1px
                 border so the panel sits flush against the tree and
                 viewer columns without a hairline seam. -->
            <Border Grid.Column="2" Background="{StaticResource SurfacePanel}"
                    x:Name="ThumbPanel">
                <Grid>
                    <controls:ThumbnailGrid x:Name="ThumbGrid" FocusVisualStyle="{x:Null}"
                                            ItemTemplate="{StaticResource LinearThumbnailTemplate}"
                                            Padding="8,2,8,2"
                                            BorderThickness="0"
                                            Loaded="ThumbGrid_Loaded"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <controls:ThumbnailGrid.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:AutoFitPanel MinItemSize="150" Spacing="6" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </controls:ThumbnailGrid.ItemsPanel>
                    </controls:ThumbnailGrid>
<!-- Empty state -->
                    <StackPanel x:Name="ThumbEmpty" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <Border Width="56" Height="56" CornerRadius="12"
                                Background="{StaticResource SurfaceCardHover}"
                                HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="Image32" FontSize="24" Foreground="{StaticResource TextQuat}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="此文件夹没有图片" FontSize="13" FontWeight="700"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,14,0,2"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="支持 JPG、PNG、GIF、WEBP、BMP、ICO" FontSize="11" FontWeight="400"
                                   Foreground="{StaticResource TextQuat}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
</Border>

            <GridSplitter Grid.Column="3" x:Name="ThumbSplitter"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="False"/>

            <!-- Image viewer (full bleed). Floating overlays (floating bar, info pill,
                 status pill) are rendered as Adorners attached to ImageViewer.
                 Adorners are part of the main window's visual tree, so they
                 automatically follow window move/resize — the stable WPF pattern. -->
            <Grid Grid.Column="4" ClipToBounds="False" x:Name="ViewerColumn"
                  Background="{StaticResource SurfaceElevated}">
                <!-- SkiaImageViewer: receives mouse events for pan/zoom/scroll.
                     The WriteableBitmap it paints in OnRender visually occludes
                     sibling Grid children with lower ZIndex — but WPF hit-testing
                     follows ZIndex, not the rendered pixels, so children with
                     higher ZIndex (the FloatingOverlayHost below) still receive
                     clicks on their actual painted regions. -->
                <controls:SkiaImageViewer x:Name="ImageViewer" Panel.ZIndex="0">
                    <controls:SkiaImageViewer.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制图片路径" Click="CtxCopyPath_Click"/>
                            <MenuItem Header="在资源管理器中打开" Click="CtxOpenInExplorer_Click"/>
                            <MenuItem Header="打印" Click="CtxPrint_Click"/>
                            <MenuItem Header="设为桌面壁纸" Click="CtxSetWallpaper_Click" Tag="destructive"/>
                        </ContextMenu>
                    </controls:SkiaImageViewer.ContextMenu>
                </controls:SkiaImageViewer>
                <!-- Floating overlays at Panel.ZIndex=10 sit ABOVE the
                     SkiaImageViewer for hit-testing. The Grid has IsHitTestVisible=True
                     (default) so it can route events to its children. Each Border
                     child uses Background brushes; their filled regions are
                     clickable. Empty regions of the Grid (no Background) are
                     hit-test transparent and pass events through to the
                     SkiaImageViewer for pan/zoom/wheel. -->
                <Grid x:Name="FloatingOverlayHost" Panel.ZIndex="10">
                    <Border x:Name="FloatingBarContent"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,18"
                            Background="{StaticResource SurfaceFloating}" BorderBrush="{StaticResource BorderStandard}" BorderThickness="1"
                            CornerRadius="{StaticResource RadiusPanel}" Padding="6,4"
                            IsHitTestVisible="True">
                        <Border.Effect>
                            <StaticResource ResourceKey="ShadowDialog"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnPrev" Style="{StaticResource LinearFloatingPrimary}"
                                    Click="BtnPrev_Click" ToolTip="上一张 (←)"
                                    IsHitTestVisible="True">
                                <ui:SymbolIcon Symbol="ChevronLeft20" FontSize="14" Foreground="White"/>
                            </Button>
                            <TextBlock x:Name="ImageIndexInfo" Text="0/0"
                                       FontFamily="{StaticResource FontMono}" FontSize="12" FontWeight="600"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="10,0" MinWidth="48" TextAlignment="Center"/>
                            <Button x:Name="BtnNext" Style="{StaticResource LinearFloatingPrimary}"
                                    Click="BtnNext_Click" ToolTip="下一张 (→)"
                                    IsHitTestVisible="True">
                                <ui:SymbolIcon Symbol="ChevronRight20" FontSize="14" Foreground="White"/>
                            </Button>

                            <Border Width="1" Background="{StaticResource BorderStandard}" Margin="8,6"/>

                            <Button x:Name="BtnFit" Style="{StaticResource LinearFloatingButton}"
                                    Click="BtnFit_Click" ToolTip="适应 (Ctrl+0)"
                                    IsHitTestVisible="True">
                                <ui:SymbolIcon Symbol="PageFit20" FontSize="14"/>
                            </Button>
                            <TextBlock x:Name="ZoomTextBlock" Text="100%"
                                       FontFamily="{StaticResource FontMono}" FontSize="12" FontWeight="600"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center" Margin="8,0" MinWidth="44" TextAlignment="Center"
                                       MouseLeftButtonUp="ZoomTextBlock_Click" Cursor="Hand"/>
                            <Border Width="1" Background="{StaticResource BorderStandard}" Margin="6,6"/>

                            <Button x:Name="BtnSlideshow" Style="{StaticResource LinearFloatingButton}"
                                    Click="BtnSlideshow_Click" ToolTip="幻灯片 (F5)"
                                    IsHitTestVisible="True">
                                <ui:SymbolIcon x:Name="SlideshowIcon" Symbol="Play20" FontSize="12"/>
                            </Button>
                            <Button x:Name="BtnFullscreen" Style="{StaticResource LinearFloatingButton}"
                                    Click="BtnFullscreen_Click" ToolTip="全屏 (Ctrl+F)" Margin="2,0,0,0"
                                    IsHitTestVisible="True">
                                <ui:SymbolIcon Symbol="FullScreenMaximize24" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border x:Name="InfoPillContent"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,14,0"
                            Background="{StaticResource SurfaceFloating}" BorderBrush="{StaticResource BorderStandard}" BorderThickness="1"
                            CornerRadius="{StaticResource RadiusPanel}" Padding="10,6"
                            IsHitTestVisible="True"
                            Cursor="Hand"
                            MouseLeftButtonUp="InfoPillContent_MouseLeftButtonUp">
                        <Border.Effect>
                            <StaticResource ResourceKey="ShadowDialog"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <!-- 8×8 status dot. Indigo once dimensions are
                                 known, gray while the lazy header-probe is
                                 still in flight. Color is set in code
                                 (UpdateCurrentImageInfo) by toggling
                                 InfoPillDot.Background. -->
                            <Border x:Name="InfoPillDot" Style="{StaticResource LinearDot}"
                                    Background="{StaticResource TextQuat}"
                                    VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="ImageInfo" Text="" FontSize="12" FontWeight="600"
                                       FontFamily="{StaticResource FontMono}"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Info popover. R70: clicking InfoPillContent
                         toggles this Popup. Position is computed in
                         code via CustomPopupPlacementCallback so the
                         popover's right edge aligns with the pill's
                         right edge (and flips above the pill if the
                         screen bottom would clip it). The Linear
                         style mirrors R62's ContextMenu: 12px radius,
                         1px hairline border, NO DropShadow (any
                         Effect in a Popup is clipped by the layered
                         window, producing the same 1px rectangular
                         sharp-corner artifact we spent R51-R62 fixing).
                         Eyebrow+content typography lives in Popover.xaml. -->
                    <Popup x:Name="InfoPopover"
                           PlacementTarget="{Binding ElementName=InfoPillContent}"
                           Placement="Bottom"
                           HorizontalOffset="0"
                           VerticalOffset="0"
                           AllowsTransparency="True"
                           StaysOpen="False"
                           PopupAnimation="Fade"
                           IsOpen="False"
                           Closed="InfoPopover_Closed">
                        <Border Background="{StaticResource SurfaceElevated}"
                                BorderBrush="{StaticResource BorderStandard}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusPanel}"
                                Padding="14,12"
                                MinWidth="240" MaxWidth="320">
                            <StackPanel>
                                <!-- Section 1: File name (single line) -->
                                <TextBlock Text="文件" Style="{StaticResource LinearPopoverEyebrow}"/>
                                <TextBlock x:Name="PopoverFileName"
                                           Text="—"
                                           Style="{StaticResource LinearPopoverValue}"/>

                                <Border Style="{StaticResource LinearPopoverDivider}"/>

                                <!-- Section 2: Size + dimensions (2 columns) -->
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="大小" Style="{StaticResource LinearPopoverEyebrow}"/>
                                        <TextBlock x:Name="PopoverSize"
                                                   Text="—"
                                                   Style="{StaticResource LinearPopoverMono}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="尺寸" Style="{StaticResource LinearPopoverEyebrow}"/>
                                        <TextBlock x:Name="PopoverDimensions"
                                                   Text="—"
                                                   Style="{StaticResource LinearPopoverMono}"/>
                                    </StackPanel>
                                </Grid>

                                <Border Style="{StaticResource LinearPopoverDivider}"/>

                                <!-- Section 3: EXIF (Make/Model/Date) -->
                                <StackPanel>
                                    <TextBlock Text="EXIF" Style="{StaticResource LinearPopoverEyebrow}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="相机" Style="{StaticResource LinearPopoverKey}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PopoverExifMake"
                                                   Text="—"
                                                   Style="{StaticResource LinearPopoverRight}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="镜头" Style="{StaticResource LinearPopoverKey}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PopoverExifModel"
                                                   Text="—"
                                                   Style="{StaticResource LinearPopoverRight}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="拍摄" Style="{StaticResource LinearPopoverKey}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PopoverExifDate"
                                                   Text="—"
                                                   Style="{StaticResource LinearPopoverRight}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Edge navigation buttons (fullscreen only). -->
                    <Border x:Name="EdgeNavLeftContent"
                            HorizontalAlignment="Left" VerticalAlignment="Center" Margin="24,0,0,0"
                            IsHitTestVisible="True" Visibility="Collapsed" Opacity="0">
                        <Button x:Name="BtnEdgePrev" Style="{StaticResource LinearEdgeButton}"
                                Click="BtnPrev_Click" ToolTip="上一张 (←)">
                            <ui:SymbolIcon Symbol="ChevronLeft20" FontSize="18"/>
                        </Button>
                    </Border>

                    <Border x:Name="EdgeNavRightContent"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"
                            IsHitTestVisible="True" Visibility="Collapsed" Opacity="0">
                        <Button x:Name="BtnEdgeNext" Style="{StaticResource LinearEdgeButton}"
                                Click="BtnNext_Click" ToolTip="下一张 (→)">
                            <ui:SymbolIcon Symbol="ChevronRight20" FontSize="18"/>
                        </Button>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- File bar hot zone. 8px wide invisible strip on the left
             edge of the main content area. When the tree is in
             "inline" mode (visible) it doesn't do anything. When the
             tree is in "collapsed" mode (zero-width column), moving
             the mouse over this strip triggers the floating
             auto-show via code-behind. In fullscreen this strip is
             disabled so it doesn't fight the edge nav. -->
        <Rectangle x:Name="TreeHotZone" Grid.Row="1"
                   Width="8" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                   Fill="Transparent"
                   IsHitTestVisible="True"
                   MouseEnter="TreeHotZone_MouseEnter"
                   MouseLeave="TreeHotZone_MouseLeave"
                   Visibility="Collapsed"/>

        <!-- Floating file bar popup. Shown when the inline tree is
             collapsed and the user mouses over the left edge. The
             popup stays open while the cursor is over either the
             hot zone or the popup itself; when it leaves both it
             closes (handled in code-behind via the inner Border's
             MouseEnter/MouseLeave). StaysOpen=True is required so
             the popup doesn't snap closed when the cursor crosses
             the gap between the 8px hot zone and the popup body. -->
        <Popup x:Name="TreeFloatingPopup"
               Placement="Left" PlacementTarget="{Binding ElementName=TreeHotZone}"
               HorizontalOffset="0" VerticalOffset="0"
               AllowsTransparency="False"
               PopupAnimation="Fade"
               StaysOpen="True"
               IsOpen="False"
               Closed="TreeFloatingPopup_Closed">
            <Border x:Name="TreeFloatingPanel"
                    Background="{StaticResource SurfacePanel}"
                    BorderBrush="{StaticResource BorderStandard}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Width="248" MaxHeight="600"
                    Margin="0,4,0,0"
                    Padding="0,4"
                    MouseLeave="TreeFloatingPanel_MouseLeave"
                    MouseEnter="TreeFloatingPanel_MouseEnter">
                <Border.Effect>
                    <StaticResource ResourceKey="ShadowDialog"/>
                </Border.Effect>
                <!-- The popup shows a clone of the inline tree; we just
                     embed FolderTree again. Both share the same Items
                     collection so selection state stays in sync. -->
                <tree:FolderTreeView x:Name="FolderTreeFloating"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextPrimary}"
                                     Padding="0,4"/>
            </Border>
        </Popup>
    </Grid>

</ui:FluentWindow>
