<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:ApertureNeo.Demo.Converters;assembly=">

    <!-- StringNotEmptyConverter: returns True if the string is not null
         and not empty. Used to make MenuItem.InputGestureText auto-
         hide the shortcut hint when unset. -->
    <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>

    <!-- Linear-styled MenuItem.
         Round 12 outer panel, 6 rounded row, 36 row height, hover at
         8% white, destructive items get a red wash on hover (both
         foreground AND background). No icon column — Q2 says drop
         it. A 3-column Grid still keeps the keyboard-shortcut hint
         (InputGestureText) and the submenu chevron in their places. -->

    <Style x:Key="LinearMenuItem" TargetType="MenuItem">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="600"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource LinearFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Single flexible column: header + spacer +
                                     shortcut + chevron all stack horizontally. -->
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ContentPresenter Grid.Column="0"
                                              x:Name="HeaderHost"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>

                            <!-- Keyboard shortcut hint. WPF fills this
                                 automatically from MenuItem.InputGestureText. -->
                            <TextBlock Grid.Column="1"
                                       x:Name="IGEShortcut"
                                       Text="{TemplateBinding InputGestureText}"
                                       FontFamily="{StaticResource FontMono}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextQuat}"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0"
                                       Visibility="Collapsed"/>

                            <!-- Submenu arrow indicator — only when this item has children -->
                            <TextBlock Grid.Column="2"
                                       x:Name="IGTSubmenuIndicator"
                                       Text="›"
                                       FontSize="16"
                                       Foreground="{StaticResource TextTertiary}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="8,0,0,0"
                                       Visibility="Collapsed"/>

                            <!-- PART_Popup with TemplateBinding IsSubmenuOpen.
                                 For leaf items this Popup is in the template but
                                 never opens (IsSubmenuOpen stays false). For parent
                                 items, IsSubmenuOpen becomes true on hover and the
                                 Popup shows the child ItemsPresenter. -->
                            <Popup x:Name="PART_Popup"
                                   Grid.Column="0" Grid.ColumnSpan="3"
                                   AllowsTransparency="True"
                                   Placement="Right"
                                   HorizontalOffset="-4"
                                   VerticalOffset="-2"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <!-- Linear 经典呈现：无阴影，1px 半透明
                                     边框 + 12px 圆角。 -->
                                <Border Background="{StaticResource SurfaceElevated}"
                                        BorderBrush="{StaticResource BorderStandard}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusPanel}"
                                        Padding="6">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                        Grid.IsSharedSizeScope="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Show the › arrow only when this item has children. -->
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="IGTSubmenuIndicator" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <!-- Show the keyboard shortcut hint when the property is
                             set to a non-empty string. InputGestureText is a
                             CLR string so we bind Visibility directly: empty
                             or null text collapses the hint. -->
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <Binding Path="InputGestureText"
                                         RelativeSource="{RelativeSource AncestorType=MenuItem}"
                                         Converter="{StaticResource StringNotEmptyConverter}"/>
                            </DataTrigger.Binding>
                            <Setter TargetName="IGEShortcut" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <!-- Standard hover: 8% white wash, foreground stays primary. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsHighlighted" Value="True"/>
                                <Condition Property="Tag" Value="destructive"/>
                                <Condition Property="IsSubmenuOpen" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource DestructiveBgHover}"/>
                            <Setter Property="Foreground" Value="{StaticResource DestructiveFg}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsHighlighted" Value="True"/>
                                <Condition Property="Tag" Value="destructive"/>
                                <Condition Property="IsSubmenuOpen" Value="True"/>
                            </MultiTrigger.Conditions>
                            <!-- Open submenu hover state (parent of submenu). -->
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource DestructiveBgHover}"/>
                            <Setter Property="Foreground" Value="{StaticResource DestructiveFg}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsHighlighted" Value="True"/>
                                <Condition Property="Tag" Value="destructive"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource DestructiveBgHover}"/>
                            <Setter Property="Foreground" Value="{StaticResource DestructiveFg}"/>
                        </MultiTrigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BtnBgHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Linear-styled Separator -->
    <Style x:Key="LinearSeparator" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="6,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Background="{TemplateBinding Background}"
                            Height="{TemplateBinding Height}"
                            Margin="{TemplateBinding Margin}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Linear-styled ContextMenu container.
         Round 12 outer panel, generous padding, layered drop shadow
         (per round 18 fix to avoid the WPF default white-strip chrome).
         MinWidth=200 keeps short-label menus from looking squeezed. -->
    <Style x:Key="LinearContextMenu" TargetType="ContextMenu">
        <!-- Round 48: set Background to SurfaceElevated so the
             outer ContextMenu surface matches the rounded Border
             inside the Popup. This paints the 1px-tall area
             outside the Border's rounded corner with the same
             off-white as the menu interior, eliminating the
             "translucent rectangle" that used to show through
             when the menu was rendered with AllowsTransparency=True. -->
        <Setter Property="Background" Value="{StaticResource SurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="MinWidth" Value="200"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <!-- Linear 经典呈现：无阴影，1px 半透明边框 +
                         12px 圆角 = 主要深度指标。设计规范明确规定
                         亮色模式用边框而非阴影表达层次。无 Effect
                         → 无 Popup 裁剪 → 无任何矩形尖角。 -->
                    <Border Background="{StaticResource SurfaceElevated}"
                            BorderBrush="{StaticResource BorderStandard}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusPanel}"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer Style="{StaticResource LinearScrollViewer}"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <Style TargetType="ScrollViewer" BasedOn="{StaticResource LinearScrollViewer}"/>
        </Style.Resources>
    </Style>

    <!-- Apply globally -->
    <Style TargetType="ContextMenu" BasedOn="{StaticResource LinearContextMenu}"/>
    <Style TargetType="MenuItem" BasedOn="{StaticResource LinearMenuItem}"/>
    <Style TargetType="Separator" BasedOn="{StaticResource LinearSeparator}"/>

</ResourceDictionary>
