<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Linear Popover Styles. R69: shared visual vocabulary for
         info popovers (InfoPill click, future tooltips, etc.).
         Pattern follows Linear's "eyebrow + content" layout — a
         11px / 510 / Tertiary section label above a 13px / 510 /
         Primary value. Mono font is used for numeric/technical
         values (Linear Mono Caption 13px in the design system). -->

    <!-- Linear Popover Eyebrow — small uppercase-ish section
         label sitting above a value. 11px / 510 / TextTertiary. -->
    <Style x:Key="LinearPopoverEyebrow" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="510"/>
        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- Linear Popover Value — primary content line below an
         eyebrow. 13px / 510 / TextPrimary. Trims at the right
         edge if the text is too long. -->
    <Style x:Key="LinearPopoverValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="510"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- Linear Popover Mono — same as PopoverValue but with the
         monospace font (Berkeley Mono in Linear; JetBrainsMono in
         our app) and 400 weight for technical numbers. No bottom
         margin because it's usually the last row in a sub-grid. -->
    <Style x:Key="LinearPopoverMono" TargetType="TextBlock"
           BasedOn="{StaticResource LinearPopoverValue}">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontWeight" Value="400"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
    </Style>

    <!-- Linear Popover Key — left-column label in a 2-column
         sub-grid (e.g., "相机" / "Sony A7M3"). 12px / TextTertiary
         / no bottom margin because the grid provides spacing. -->
    <Style x:Key="LinearPopoverKey" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="510"/>
        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
        <Setter Property="Margin" Value="0,0,12,4"/>
    </Style>

    <!-- Linear Popover Right — right-column value in a 2-column
         sub-grid. 12px / TextSecondary / Mono for camera model etc. -->
    <Style x:Key="LinearPopoverRight" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="400"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- Linear Popover Divider — 1px hairline between sections.
         BorderSubtle = #12000000 = 7% black on white. -->
    <Style x:Key="LinearPopoverDivider" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{StaticResource BorderSubtle}"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

</ResourceDictionary>
